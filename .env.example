# Supabase — get from https://supabase.com/dashboard/project/[id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paddle Billing Sandbox — get from https://sandbox-vendors.paddle.com
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=

# Paddle Price IDs — create prices in Paddle Catalog
NEXT_PUBLIC_PADDLE_PRICE_ID_MONTHLY=
NEXT_PUBLIC_PADDLE_PRICE_ID_YEARLY=
PADDLE_PRICE_ID_MONTHLY=
PADDLE_PRICE_ID_YEARLY=
